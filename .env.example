# ħħ LLM Backend ħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħ
# Choose: kimi (cloud) or ollama (local)
LLM_BACKEND=kimi

# Kimi (Moonshot) ― required when LLM_BACKEND=kimi
KIMI_API_KEY=sk-...

# Ollama ― used when LLM_BACKEND=ollama
# Make sure Ollama is running: ollama serve
# Pull models first: ollama pull qwen2.5:7b && ollama pull nomic-embed-text
OLLAMA_BASE_URL=http://localhost:11434/v1

# ħħ AI Models ħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħ
# Kimi models:
#   LLM_MODEL_FAST=moonshot-v1-8k
#   LLM_MODEL_LARGE=moonshot-v1-32k
#   EMBEDDING_MODEL=moonshot-v1-embedding
#
# Ollama models (examples):
#   LLM_MODEL_FAST=qwen2.5:7b
#   LLM_MODEL_LARGE=qwen2.5:14b
#   EMBEDDING_MODEL=nomic-embed-text
LLM_MODEL_FAST=moonshot-v1-8k
LLM_MODEL_LARGE=moonshot-v1-32k
EMBEDDING_MODEL=moonshot-v1-embedding

# ħħ Database ħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħ
DB_PATH=db/local_files.duckdb

# ħħ Directories ħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħ
WATCH_DIR=input
OUTPUT_DIR=output

# ħħ Chunking ħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħ
CHUNK_MAX_TOKENS=500
CHUNK_OVERLAP_TOKENS=50

# ħħ Processing ħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħħ
PROCESS_BATCH_SIZE=10
EMBED_BATCH_SIZE=16
